VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Server-side only (used by api/hubspot-tasks.js) — do NOT prefix with VITE_,
# these must never be bundled into client-side code.
HUBSPOT_TOKEN=pat-na1-xxxxxxxx
HUBSPOT_PORTAL_ID=12345678
# Optional, defaults to America/Sao_Paulo.
HUBSPOT_TIMEZONE=America/Sao_Paulo

# Server-side only (used by api/calendar-events.js) — published iCloud
# calendar .ics link (Calendar app -> right-click calendar -> Share Calendar
# -> Public Calendar). Treat as a secret: anyone with this URL can read the
# calendar. CALENDAR_ICS_URL is always pastel green; add CALENDAR_ICS_URL_2,
# _3, etc. for additional calendars, each gets its own fixed color.
CALENDAR_ICS_URL=webcal://p00-caldav.icloud.com/published/2/xxxxxxxx
# CALENDAR_ICS_URL_2=webcal://p00-caldav.icloud.com/published/2/yyyyyyyy

# Server-side only (used by api/reminders.js and api/reminders-webhook.js).
# CalDAV can't reach real Reminders data on accounts migrated to Apple's
# newer Reminders engine, so instead a Shortcuts automation on the user's own
# device POSTs a fresh snapshot to /api/reminders-webhook periodically, and
# api/reminders.js just reads the latest snapshot back out of Supabase.
# SUPABASE_SERVICE_ROLE_KEY bypasses RLS — never expose it client-side, and
# never reuse a key that's been pasted anywhere insecure.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
# Shared secret the Shortcut must send as "Authorization: Bearer <this>".
REMINDERS_WEBHOOK_SECRET=a-long-random-string

# Server-side only (used by api/notion-tasks.js). Notion integration token
# (Settings -> Connections -> Develop or manage integrations) with the tasks
# database shared to it, plus that database's ID from its URL.
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_TASKS_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Projetos database ID, also shared with the integration — tasks are grouped
# by project using this database's own relation back to tasks (the tasks'
# own project relation is unreliable via the API). Optional: if unset,
# everything falls under a single "Sem Projeto" group.
NOTION_PROJECTS_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
